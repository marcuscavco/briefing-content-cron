# ── Públicas (entram no bundle do client — APENAS estas duas) ──────────────
# Projeto local: valores de `supabase status`. Produção: projeto briefing-saas.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-only (NUNCA prefixar com NEXT_PUBLIC_) ──────────────────────────
# Bypass total de RLS. Só pode ser importada via packages/db/src/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Chave Claude da plataforma (motor de curadoria). Usada apenas em rotas server/jobs.
ANTHROPIC_API_KEY=

# Embeddings da memória semântica (voyage-3.5-lite). Sem a key, dev usa fallback hash.
VOYAGE_API_KEY=

# Autentica o Vercel Cron no /api/cron/tick (a Vercel injeta como Bearer token)
CRON_SECRET=

# Cifra de credenciais de fonte (32 bytes base64: openssl rand -base64 32)
CREDENTIALS_ENCRYPTION_KEY=

# ── Entrega (Fase 3) — sem estas envs, o canal fica `skipped_disabled` no log ─
# Email transacional (resend.com). Sem domínio verificado, use onboarding@resend.dev
# como EMAIL_FROM (só entrega para o email da conta Resend).
RESEND_API_KEY=
EMAIL_FROM=

# WhatsApp via Z-API (api.z-api.io) — chamada direta, sem Worker proxy.
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Base pública do app (links do email: dashboard, unsubscribe). Default: URL de produção.
APP_BASE_URL=

# ── OAuth Google no stack local (opcional; produção configura no dashboard) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Ingestão (produção: fetch via Worker rss-proxy; vazio = fetch direto, só dev) ─
RSS_PROXY_URL=
RSS_PROXY_TOKEN=
