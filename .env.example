# ── Públicas (entram no bundle do client — APENAS estas duas) ──────────────
# Projeto local: valores de `supabase status`. Produção: projeto briefing-saas.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-only (NUNCA prefixar com NEXT_PUBLIC_) ──────────────────────────
# Bypass total de RLS. Só pode ser importada via packages/db/src/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Chave Claude da plataforma (motor de curadoria). Usada apenas em rotas server/jobs.
ANTHROPIC_API_KEY=

# ── Multi-provider LLM (Fase B) — roteamento por estágio, sem deploy ─────────
# Formato vendor:modelo (anthropic | google | xai). Vazio = defaults abaixo.
# LLM_CLUSTER=anthropic:claude-sonnet-5   (clusterização — 76% do custo)
# LLM_POSTS=anthropic:claude-sonnet-5     (posts — voz do produto)
# LLM_CHEAP=anthropic:claude-haiku-4-5    (judges baratos)
LLM_CLUSTER=
LLM_POSTS=
LLM_CHEAP=
# Necessárias apenas se algum LLM_* apontar para google:/xai:
GEMINI_API_KEY=
XAI_API_KEY=

# Embeddings da memória semântica (voyage-3.5-lite). Sem a key, dev usa fallback hash.
VOYAGE_API_KEY=

# Autentica o Vercel Cron no /api/cron/tick (a Vercel injeta como Bearer token).
# O pg_cron do Supabase usa o MESMO valor (secret `cron_secret` no Vault).
CRON_SECRET=

# ── Worker (Fase A — escalabilidade) ─────────────────────────────────────────
# Jobs processados em paralelo por invocação do tick (default 5)
WORKER_CONCURRENCY=
# Antecedência (min) do enfileiramento antes do delivery_time (default 60):
# entrega às 07:00 → job entra na fila às 06:00
DISPATCH_LEAD_MINUTES=
# WhatsApp do operador para alertas (fila represada / jobs failed), formato
# literal Z-API (55 + DDD + número). Vazio = alertas desligados.
OPS_ALERT_PHONE=

# Cifra de credenciais de fonte (32 bytes base64: openssl rand -base64 32)
CREDENTIALS_ENCRYPTION_KEY=

# ── Entrega (Fase 3) — sem estas envs, o canal fica `skipped_disabled` no log ─
# Email transacional (resend.com). DECISÃO (2026-07-08): canal email fica
# DESLIGADO por enquanto (só WhatsApp). Para ativar de verdade é preciso
# verificar um domínio próprio em resend.com/domains (3 registros DNS) e trocar
# EMAIL_FROM para um endereço desse domínio (ex.: briefing@oempresarionerd.com)
# — sem isso o Resend só entrega para o email da própria conta Resend.
RESEND_API_KEY=
EMAIL_FROM=

# WhatsApp via Z-API (api.z-api.io) — chamada direta, sem Worker proxy.
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Base pública do app (links do email: dashboard, unsubscribe). Default: URL de produção.
APP_BASE_URL=

# ── Instagram (Fase 5) — provedor Apify; sem token, fontes IG reportam erro claro ─
# Kill-switch global em app_config.instagram_connector_enabled (backoffice /admin);
# feature por plano em plans.features.instagram (hoje: pro).
APIFY_TOKEN=

# ── OAuth Google no stack local (opcional; produção configura no dashboard) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Ingestão (produção: fetch via Worker rss-proxy; vazio = fetch direto, só dev) ─
RSS_PROXY_URL=
RSS_PROXY_TOKEN=
